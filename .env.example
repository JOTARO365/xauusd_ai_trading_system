# ============================================================
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกข้อมูลจริง
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env  (Windows)
# ============================================================

# ── Claude API ───────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Alpha Vantage (macro data for scripts/update_regime.py) ──────────
# free key: https://www.alphavantage.co/support/#api-key (25 req/day)
# ใช้ดึง CPI/Fed funds/10Y → อัปเดต macro_regime.md (รันสัปดาห์ละครั้งพอ)
ALPHAVANTAGE_API_KEY=your_alphavantage_key_here

# ── X / Twitter ──────────────────────────────────────────────
X_USERNAME=your_x_username
X_PASSWORD=your_x_password
X_EMAIL=your_x_email

# ── MT5 Account (Windows only) ───────────────────────────────
MT5_LOGIN=your_mt5_login_number
MT5_PASSWORD=your_mt5_password
MT5_SERVER=your_broker_server_name

# ── PM2 ──────────────────────────────────────────────────────
PM2_APP_NAME=main

# ── Dashboard auth (opt-in) ──────────────────────────────────
# ตั้งทั้งคู่เพื่อเปิด HTTP Basic Auth ทุก route ของ dashboard :5050
# (defense-in-depth เสริม Tailscale). ไม่ตั้ง = ปิด auth (โหมดเดิม)
# DASHBOARD_USER=admin
# DASHBOARD_PASS=use_a_long_random_passphrase

# ── Database — เลือก 1 โหมด ──────────────────────────────────
#
# โหมด Owner (บอทคุณเอง — เข้า Supabase ตรง, เห็นทุก account):
#   ใช้ service_role key → bypass RLS (เก็บเป็นความลับ! อย่า commit อย่าแจกใคร)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
#   anon key — ใช้เฉพาะชั้น web (Supabase Auth + JWT); บอทไม่ต้องใช้
# SUPABASE_ANON_KEY=your_supabase_anon_key
#
# โหมด User ทั่วไป (bot คนอื่น — ส่งผ่าน API proxy, ไม่เห็น Supabase key ใดๆ):
# TRADING_API_URL=https://your-proxy.onrender.com
# TRADING_API_KEY=key_ที่ได้รับจาก_owner
#
# หมายเหตุ:
#   • ถ้าตั้ง TRADING_API_URL → ระบบใช้ proxy อัตโนมัติ (ไม่ต้องมี Supabase key)
#   • RLS เปิดอยู่ → ห้ามใช้ anon key เดี่ยวๆ กับบอท (จะถูก deny); owner ต้องใช้ service_role
#   • เก่า SUPABASE_KEY ยังใช้ได้ (fallback) แต่แนะนำเปลี่ยนเป็น SUPABASE_SERVICE_KEY

# ── Trading Config ───────────────────────────────────────────
SYMBOL=GOLD#
START_BALANCE=2000
LOT_MODE=auto
FIXED_LOT=0.01
MIN_LOT=0.01
MAX_LOT=0.01
RISK_PER_TRADE=0.50
MAX_DAILY_LOSS=1.00
MAX_OPEN_TRADES=4
DEFAULT_SL_PIPS=2000
DEFAULT_TP_PIPS=5000
MIN_RR_RATIO=2.0
MAX_PENDING_BUY=4
MAX_PENDING_SELL=4
PENDING_EXPIRY_HOURS=48
CONF_FULL_SIZE_AT=80
CONF_MIN_SCALE=0.5
# EMA_PULLBACK toxicity gate — block EMA_PULLBACK เมื่อ SL กว้าง (ATR สูง) หรือ confidence ต่ำ
EMA_PULLBACK_MAX_SL=1500
EMA_PULLBACK_MIN_CONF=70
# Hard-block EMA_PULLBACK ทั้ง type (default true) — conf≥75 ยัง WR31%/−594; false=ใช้แค่ sl/conf limits ด้านบน
EMA_PULLBACK_BLOCK=true
# ตั้ง SL ให้ open position ที่ไม่มี SL อัตโนมัติทุก cycle (ครอบ SYSTEM+MANUAL) ที่ DEFAULT_SL_PIPS จากราคาปัจจุบัน
# กันรู: manage_* ทุกตัวเดิม skip ไม้ sl==0 → ไม่มีใครตั้งให้. false=ปิด (ไม่ยุ่งไม้ no-SL)
AUTO_SL_PROTECT=true
# ความกว้าง SL ของ AUTO_SL_PROTECT (pips จากราคาปัจจุบัน) — 0 = ใช้ DEFAULT_SL_PIPS
# เทรดมือแล้วรู้สึก SL ชิดเกิน → ตั้ง 2000-3000 (ไม่กระทบ SL ของไม้บอท)
AUTO_SL_PIPS=0
# ทุกกลไกที่เลื่อน SL (breakeven/force-BE/dynamic-TP lock) ห้ามวาง SL ใกล้ราคาปัจจุบันกว่านี้
# (เดิม force-BE เหลือ gap 10p, dyn-TP 200p, BE-cap×HTF 500p = โดน noise กวาด; 0=ปิด guard)
SL_MIN_GAP_PIPS=800
# เพดานไม้ SYSTEM ต่อวัน (market + pending fill) — เบรกกันวันพายุ/revenge-trade (0=ปิด)
# replay 247 ไม้ (110465856): ไม้ #7+ ของวัน = −411 ขณะไม้ 1-6 = +139.88; นับจาก MT5 entry deals จริง
MAX_TRADES_PER_DAY=6

# ห้ามเข้าสวนเทรนด์ D1 (EMA20+slope จากแท่งปิดแล้ว) — hard block ทั้ง market+pending ทุกระบบ
# replay 251 ไม้ no-lookahead: counter-D1 = −248; มิ.ย. BUY สวน D1-BEARISH = −242 (conf 78-82 ก็แพ้)
HTF_DIRECTION_BLOCK=true
# โหมดชนะยุคทอง (พ.ค.): M15-STRONG + H1 + H4 เรียงแถวตรงทิศ → ยกเว้น counter-spike/HTF-direction
# ให้ไม้นั้น (dip/reversal ตามเทรนด์เข้าได้) — เกราะอื่นครบ, ไม้ติด tag "RIDE" วัดผลแยกได้
MOMENTUM_RIDE=true

# ── AI cost throttles (Track-1 07-03) ─────────────────────────
# ตลาดเงียบ + ไม่มีไม้ SYSTEM → ยืดรอบ AI เป็น 30 นาที (default true; false = ปิด)
AI_IDLE_GATE=true
# performance report cooldown วินาที (default 14400 = 4 ชม.)
REPORTER_COOLDOWN_SEC=14400
# หมายเหตุ: throttle "มีไม้เปิด → AI ทุก 5 นาที" นับเฉพาะไม้ SYSTEM แล้ว (ไม้มือไม่ปลุก AI)

# ── Decision gates & anti-fade guards ────────────────────────
# (replay 489 ไม้ 2026-06-10 — แก้ค่าแล้ว reload เองทุก cycle ไม่ต้อง restart)
MIN_TECH_CONF=62              # conf floor ทุก entry (conf 50-59 = WR 23.5% โซนพิษ)
ASIAN_MIN_CONF=72             # Asian/quiet session ทุก entry ต้อง ≥ นี้ (Asian = -115/ไม้)
COUNTER_SPIKE_PIPS=500        # ห้ามเข้าสวนสไปก์ ≥ นี้ (ราคาพุ่งขึ้น=ห้าม SELL) | 0=ปิด
NEWS_FIRST=true               # ข่าวชี้ทิศชัด → บล็อกเข้าสวนข่าว
NEWS_BIAS_MIN_CONF=55         # analyst conf ขั้นต่ำที่ถือว่า "ข่าวชี้ทิศชัด"
HTF_FADE_BLOCK=true           # ห้าม SELL ที่ D1/W1 SUPPORT / BUY ที่ RESISTANCE
NEWS_OVERRIDE_TREND=true      # option C: ตรงข่าว + price action ยืนยัน → เข้าสวนเทรนด์ H4 ได้
NEWS_CONFIRM_PIPS=500         # สไปก์ตามทิศขั้นต่ำที่นับเป็น "price action ยืนยัน"
NEWS_OVERRIDE_MIN_CONF=50     # conf ขั้นต่ำของ option C
HTF_REVERSAL_MIN_CONF=70      # counter-H4 BUY@D1/W1 support / SELL@resistance (reversal) ต้อง conf ≥ นี้ | 999=ปิด
TREND_CONT_CONF=65            # conf สังเคราะห์ของ TREND_CONT/HTF override (NNLB)
TREND_CONT_MAX_DIST_PCT=0.3   # TREND_CONT ต้องใกล้ H1 EMA20 ≤ นี้ (% — pullback จริง)
NNLB_FASTPATH=true            # false = NNLB ผ่าน Claude decision เสมอ (ไม่เปิด order ตรง)
MIN_AI_EQUITY=5               # ทุน (สกุลบัญชี) ต่ำกว่านี้ → ไม่เรียก AI เลย | 0=ปิด
                              # ⚠ หน่วย = สกุลของบัญชี MT5: บัญชี USD ใช้ ~5 ($5≈180฿) / บัญชี THB ใช้ ~150
                              #   (code default = 150 — สเกล THB; บัญชี USD ที่ไม่ตั้งค่านี้จะโดนบล็อกทั้งที่มี $100+)

# ── Position-Guardian thread ─────────────────────────────────
# daemon thread เฝ้าไม้เปิดถี่ๆ (breakeven/trailing/momentum-exit) ระหว่าง AI cycle ที่ช้า
# *** เปิดบน VM หลังทดสอบกับ MT5 จริงแล้วเท่านั้น *** (concurrency + เงินจริง)
GUARDIAN_ENABLED=false
GUARDIAN_INTERVAL_SEC=4

# ── Specialist agents (multi-TF entries, Layer-A) — 0 extra LLM calls (pure Python) ──
# SHADOW  = เก็บ full chart_data + candidates ลง logs/spec_shadow.jsonl (data collection, 0 token,
#           ไม่กระทบ decision). เปิดบน VM เพื่อสะสม data 2-4 สัปดาห์ก่อน validate/enable
# ENABLED = ป้อน spec advisory ให้ decision_maker (ไม่แตะ gate/cap 6/floor 62). เปิดหลัง replay ผ่านเท่านั้น
SPECIALIST_SHADOW=false
SPECIALIST_ENABLED=false

# ── Token cost knobs ─────────────────────────────────────────
# reporter perf-report ห่างกี่วินาที (ยิ่งนาน = token น้อยลง). default 3600 (60 min)
REPORTER_COOLDOWN_SEC=3600
# ── Idle AI gate — ลด AI call ตอนตลาดเงียบจริง (วัด momentum สด ไม่ใช่นาฬิกา) ──
# วัด recent M15 range เทียบ median ของตัวเอง (self-calibrate ตาม volatility regime).
# เงียบจริง → ยืด throttle จาก AI_MIN(15น) เป็น AI_QUIET_INTERVAL. price-spike override
# ยังกันการกระชากกะทันหัน; probe error = ถือว่าไม่เงียบ (รัน AI). *** เปิดบน VM หลังทดสอบ ***
AI_IDLE_GATE=false
AI_QUIET_INTERVAL_SECS=1800    # idle + เงียบจริง → ยิง AI ทุก 30 นาที (จาก 15)
AI_QUIET_RATIO=0.6            # recent(4 แท่ง)/median(50 แท่ง) < 0.6 = เงียบจริง
PORTFOLIO_PROTECTION=true
STREAK_PROTECTION=true
DYNAMIC_TP=true
MAX_LOSING_STREAK=5
STREAK_MIN_CONFIDENCE=62
HEDGE_BUFFER_PIPS=1000

# ── Breakeven ────────────────────────────────────────────────
# trigger BE เมื่อ profit ≥ X × SL distance จริงของ position
# 0.8 = 80% ของ SL (ป้องกันโดนหน้าทุนตอนกำไรยังน้อย)
BE_TRIGGER_R=0.8
BE_BUFFER_PIPS=200
# ราคาต้องค้างเหนือ trigger กี่ cycle ก่อน SL ย้าย (ป้องกัน "แตะแล้วดีดกลับ")
# 2 cycles ≈ 4-10 นาที | เพิ่มเป็น 3-4 เมื่อตลาด consolidate ที่ HTF zone
BE_CONFIRM_CYCLES=2
# เพดาน trigger (pips): ไม้ SL กว้าง (HTF 3500p × 2.0R = 7000p) จะ lock กำไรไม่ทัน
# → cap ให้ขยับ SL หน้าทุนเมื่อกำไรถึง X pips ไม่ว่า R เท่าไร (กันอาการ "ราคาขึ้นแต่ SL ไม่ขยับ")
BE_MAX_TRIGGER_PIPS=1500

# ── Trailing Stop (Swing Low/High — Higher TF) ───────────────
# true  = ขยับ SL ไปที่ swing low/high ของ TF ที่เลือก (3 แท่งล่าสุด)
# false = ปิด
TRAILING_STOP=false
TRAILING_ATR_TF=D1        # H4 | D1 | W1
TRAILING_ATR_MULT=1.5     # buffer เป็น $ ใต้ swing low (BUY) / เหนือ swing high (SELL)

# ── RAG-based Lesson Retrieval ───────────────────────────────
# true  = จำความผิดพลาดและนำมาเตือน DecisionMaker (ต้องใช้ GEMINI_API_KEY)
# false = ปิด
LESSON_LEARNING=true

# ── DRY_RUN mode ─────────────────────────────────────────────
# true  = ทดสอบ pipeline ทั้งหมดแต่ไม่ส่ง order จริงไป MT5
# false = รันปกติ (ส่ง order จริง)
DRY_RUN=false

# ── NNLB mode (No-Risk-No-Lamborghini) ───────────────────────
# true  = ข้าม gates / money management ทั้งหมด — lot scale ตาม equity tier
# false = ปกติ (แนะนำ)
# *** BASE_EQUITY / EQUITY_PER_LOT เป็น USD → แปลงเป็นสกุลบัญชีอัตโนมัติ ***
# (ทอง 1 pip = $1 → USD=×1, THB=×~36) ค่าชุดเดียวใช้ได้ทั้งบัญชี USD และ THB
NNLB_MODE=false
# equity ขั้นต่ำ (USD) ก่อนอนุญาตให้เข้า order — ต่ำกว่านี้ skip
NNLB_BASE_EQUITY=100
# กำไร (USD) ต่อการเพิ่ม 0.01 lot
# เช่น BASE=25, PER_LOT=25, MIN_LOT=0.01 → equity $75 (กำไร $50) → lot=0.03
NNLB_EQUITY_PER_LOT=100
# max loss ต่อ trade (% ของ equity) — ลด lot อัตโนมัติให้อยู่ใน budget
# ถ้า MIN_LOT ยังเกิน budget → ใช้ MIN_LOT ต่อไป (NNLB รับความเสี่ยง)
NNLB_MAX_LOSS_PCT=25

# ── X Accounts / Keywords ────────────────────────────────────
X_ACCOUNTS_TO_FOLLOW=kun_purich,cnnbrk,BBCBreaking,ZeroHedge,markets
X_KEYWORDS=XAUUSD,gold,XAU,bullion,Fed,inflation,Iran,Israel,ceasefire,geopolitical,war,oil,crude,CPI,rate cut,Hormuz,CENTCOM,Kharg,PPI,FOMC,Pakistan,Pezeshkian,Geneva
