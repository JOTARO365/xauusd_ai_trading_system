# ============================================================
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกข้อมูลจริง
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env  (Windows)
# ============================================================

# ── Claude API ───────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── X / Twitter ──────────────────────────────────────────────
X_USERNAME=your_x_username
X_PASSWORD=your_x_password
X_EMAIL=your_x_email

# ── MT5 Account (Windows only) ───────────────────────────────
MT5_LOGIN=your_mt5_login_number
MT5_PASSWORD=your_mt5_password
MT5_SERVER=your_broker_server_name

# ── PM2 ──────────────────────────────────────────────────────
PM2_APP_NAME=main

# ── Trading Config ───────────────────────────────────────────
SYMBOL=XAUUSD
START_BALANCE=2000
LOT_MODE=auto
FIXED_LOT=0.01
MIN_LOT=0.01
MAX_LOT=0.01
RISK_PER_TRADE=0.50
MAX_DAILY_LOSS=1.00
MAX_OPEN_TRADES=4
DEFAULT_SL_PIPS=1000
DEFAULT_TP_PIPS=3000
MIN_RR_RATIO=1.5
MAX_PENDING_BUY=4
MAX_PENDING_SELL=4
PENDING_EXPIRY_HOURS=48
PORTFOLIO_PROTECTION=true
STREAK_PROTECTION=true
DYNAMIC_TP=true
MAX_LOSING_STREAK=5
STREAK_MIN_CONFIDENCE=62
HEDGE_BUFFER_PIPS=1000

# ── X Accounts / Keywords ────────────────────────────────────
X_ACCOUNTS_TO_FOLLOW=kun_purich,cnnbrk,BBCBreaking,ZeroHedge,markets
X_KEYWORDS=XAUUSD,gold,XAU,bullion,Fed,inflation
