# ============================================================
# .env.example — mirror ของ .env จริง (operating config เปิด algo ครบ), secret ถูก redact
#   cp .env.example .env  แล้วกรอก secret จริง (คีย์ที่ลงท้าย _here)
#   regen: python scripts/sync_env_example.py
# ============================================================

# ============================================================
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกข้อมูลจริง
#   cp .env.example .env   (Linux/Mac)
#   copy .env.example .env  (Windows)
# ============================================================

# ── Claude API ───────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── X / Twitter ──────────────────────────────────────────────
X_USERNAME=your_x_username_here
X_PASSWORD=your_x_password_here
X_EMAIL=your_x_email_here

# ── MT5 Account (Windows only) ───────────────────────────────

# # XM
MT5_LOGIN=your_mt5_login_here
MT5_PASSWORD=your_mt5_password_here
MT5_SERVER=your_mt5_server_here

# XM DEMO
# MT5_LOGIN=your_mt5_login_here
# MT5_PASSWORD=your_mt5_password_here
# MT5_SERVER=your_mt5_server_here

# RoboForex
# MT5_LOGIN=your_mt5_login_here
# MT5_PASSWORD=your_mt5_password_here
# MT5_SERVER=your_mt5_server_here

# CXM
# MT5_LOGIN=your_mt5_login_here
# MT5_PASSWORD=your_mt5_password_here
# MT5_SERVER=your_mt5_server_here

# FBS
# MT5_LOGIN=your_mt5_login_here
# MT5_PASSWORD=your_mt5_password_here
# MT5_SERVER=your_mt5_server_here

# ── PM2 ──────────────────────────────────────────────────────
PM2_APP_NAME=main

# ── Trading Config (10,000 THB ≈ $285) ───────────────────────
# SYMBOL=XAUUSD
SYMBOL=GOLD#
START_BALANCE=50000     # THB — ใช้คำนวณ drawdown % เท่านั้น (demo 50k, 2026-07-21)
LOT_MODE=fixed           # FIXED เสมอ — ทุนน้อยเกินไปให้ auto scale
FIXED_LOT=0.01           # ใช้เฉพาะ LOT_MODE=fixed (NNLB mode ข้ามค่านี้)
MIN_LOT=0.01             # NNLB base lot (profit=0) — tier เพิ่มจากนี้
MAX_LOT=0.03             # cap ชั่วคราว — รอ R:R fix แล้วค่อยขยาย (เดิม 0.10)
RISK_PER_TRADE=2.0       # nominal (ไม่มีผลในโหมด fixed) — ใช้อ้างอิงใน log เท่านั้น
MAX_DAILY_LOSS=30.0      # 30% = 3,000 THB/วัน ≈ แพ้ได้ 4-5 ไม้
MAX_OPEN_TRADES=2        # เปิดพร้อมกันสูงสุด 2 (= max exposure $200)
DEFAULT_SL_PIPS=1000     # SL ลดจาก 2000 → 1000 ($100 max loss ต่อ trade)
DEFAULT_TP_PIPS=3000     # TP = 3R ($300 หากชนะ)
MIN_RR_RATIO=2.0
MAX_PENDING_BUY=2        # ลดจาก 4 → 2
MAX_PENDING_SELL=2
PENDING_EXPIRY_HOURS=24  # ลดจาก 48 → 24h (pending ที่ค้างนานเสี่ยงเปิดในตลาดที่เปลี่ยนแล้ว)
CONF_FULL_SIZE_AT=80
CONF_MIN_SCALE=0.5
# EMA_PULLBACK toxicity gate (วิเคราะห์ 2026-06: SL กว้าง/conf ต่ำ → ~0% WR)
EMA_PULLBACK_MAX_SL=1500    # SL pips >= ค่านี้ → block EMA_PULLBACK
EMA_PULLBACK_MIN_CONF=70    # confidence < ค่านี้ → block EMA_PULLBACK
PORTFOLIO_PROTECTION=true
STREAK_PROTECTION=true
DYNAMIC_TP=true
TP_EXT_MAX=4                  # dynamic-TP ขยาย TP ได้สูงสุดกี่ครั้ง/ไม้ (เดิม 2 → 4, 07-23)
TP_EXT_PIPS=400              # ระยะ extend TP ต่อรอบ (fallback เมื่อไม่มีแนว S/R ถัดไป)
TP_EXT_NEAR_PIPS=150         # ราคาห่าง TP ≤ นี้ (pips) จึงพิจารณา extend
TP_EXT_MOMENTUM_MIN=4        # momentum score ≥ นี้ (max 5) จึง extend
TP_EXT_COOLDOWN_SECS=900     # cooldown ระหว่าง extend แต่ละครั้ง (วินาที)
TP_EXT_SL_LOCK_PIPS=200      # trail SL ห่างราคา X pips เมื่อ extend (floor ด้วย SL_MIN_GAP)
MAX_LOSING_STREAK=3      # เข้มกว่าปกติ: หยุดหลังแพ้ 3 ครั้งติดกัน (เดิม 5)
STREAK_MIN_CONFIDENCE=68  # confidence ขั้นต่ำหลัง streak (เดิม 62)
HEDGE_BUFFER_PIPS=10000
MIN_AI_EQUITY=135       # equity (บาท) ต่ำกว่านี้ → ไม่รัน AI — บัญชี THB: เทรดเมื่อทุน ≥1000฿

# ── Supabase (Owner — เข้า DB ตรง) ───────────────────────────
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_key_here

# ── API Proxy (User mode — ถ้าตั้งค่านี้จะข้าม Supabase ด้านบน)
# TRADING_API_URL=https://your-proxy.onrender.com
# TRADING_API_KEY=your_trading_api_key_here

# ── Gemini (Google AI) — สำหรับ news embedding + vector search ──
# รับ API key ฟรีที่: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── Breakeven ────────────────────────────────────────────────
BE_TRIGGER_R=1.2         # trigger BE เมื่อกำไร ≥ 1.2× SL (position ยืนยันทิศทางแล้ว)
BE_BUFFER_PIPS=300       # lock ขั้นต่ำ 300p (code จะใช้ max(300, profit*30%) อัตโนมัติ)
BE_CONFIRM_CYCLES=5
HTF_BE_TRIGGER_R=2.0     # D1/W1: trigger เมื่อกำไร ≥ 2× SL (ให้วิ่งได้ไกลกว่า)
HTF_BE_BUFFER_PIPS=1000  # D1/W1: lock ขั้นต่ำ 1000p

# ── Trailing Stop (Swing Low/High — Higher TF) ───────────────
TRAILING_STOP=true
TRAILING_ATR_TF=H4          # timeframe สำหรับหา swing high/low
TRAILING_ATR_MULT=0.3        # × ATR(H4) buffer ใต้/เหนือ swing (vol-adaptive; 0.3=พอกัน wick ไม่ไกลไป 07-23)
TRAILING_MIN_PROFIT_R=1.5    # เริ่ม trail เมื่อกำไร ≥ 1.5× SL (position ยืนยันทิศทาง)
TRAILING_LOOKBACK=8          # มองย้อนหลัง 8 แท่ง H4 = 32 ชั่วโมง (เดิม 3 = 12h)

# ── RAG-based Lesson Retrieval ───────────────────────────────
LESSON_LEARNING=true

# ── DRY_RUN mode ─────────────────────────────────────────────
DRY_RUN=false

# ── REGIME_LIVE — algo entry mode (2026-07-19) ───────────────
# algo (momentum-in-TREND) = ตัวเดียวที่วาง order; LLM→sentiment; pending/ZRE/swing ปิดอัตโนมัติ.
# lot 0.01 (fixed), daily-cap/SL guard เดิมทำงาน. ⚠️ algo ยังไม่มี validated edge → เก็บ data.
# kill switch = REGIME_LIVE=false (live-reload, ไม่ต้อง restart). monitor: python scripts/regime_monitor.py
REGIME_LIVE=true
# per-tick executor (2026-07-20, user request) — daemon เช็คราคา vs Donchian level ทุก REGIME_TICK_INTERVAL_SEC
# realtime เข้าเร็วกว่ารอ bar-close. per-cycle ปิดอัตโนมัติเมื่อ tick ON. ⚠️ thread start ตอน boot → ต้อง restart
# kill = REGIME_LIVE_TICK=false. ยังคง lot 0.01 + daily-cap + SL/TP ในตัว
REGIME_LIVE_TICK=true
REGIME_LOOP_SECS=5           # main loop 5 วิ (จัดการไม้/trailing/journal/pending gate responsive; entry=tick 3s แยก)
# ── algo v2 (2026-07-20, DESIGN_algo_v2.md) — S/R-aware entry/exit ─────────────
# P-B fade → journal shadow (0 order): เก็บ counterfactual fade data (BUY@support/SELL@resistance + veto/gate)
REGIME_SR_ENTRY=true
# P-D exit: TP ยิงแนว S/R ตามความสำคัญ (H1 ใกล้/W1 ไกล) + trailing ใต้ support/เหนือ resistance − 0.3ATR
REGIME_SR_EXIT=true
# P-E sizing: lot ไม้ ALGO = risk-based (equity × RISK_PCT / sl_pips, cap MAX_RISK_PCT, clamp MIN/MAX_LOT)
REGIME_SR_SIZING=true
REGIME_SR_RISK_PCT=0.005     # 0.5% ของ equity ต่อไม้ (โตตามทุน, floor MIN_LOT)
# P-C pending regime-routed (2026-07-20, user "เปิดทั้ง fade+breakout"): entry เปลี่ยนเป็น pending orders
# → tick/per-cycle executor ยืนดูอัตโนมัติ (ไม่เข้าซ้ำ). broker fill ตอนราคาแตะแนว
# TREND → BUY_STOP/SELL_STOP breakout ที่ Donchian
REGIME_PENDING=false        # hybrid (2026-07-20): TREND→tick market execute / RANGE→fade pending (ไม่ใช้ STOP straddle)
# RANGE → BUY_LIMIT@แนวรับแข็ง / SELL_LIMIT@แนวต้านแข็ง (veto break_pct≥60) + cancel ตอนราคาใกล้+momentum break
# ⚠️ RANGE fade ยังไม่ผ่าน validation — เปิดเก็บ data จริง (lot risk 0.5%, MAX 0.03). kill = flag=false
REGIME_PENDING_FADE=true
# SHADOW-FILL (2026-07-20, user "เข้า order แม้ไม่มีทุน"): algo วาง order แบบ paper (ไม่วางจริง/ไม่ใช้ทุน/ไม่เช็ค margin)
# เฉพาะไม้ ALGO — ไม้จริง legacy บริหารปกติ (DRY_RUN=false). journal เก็บ counterfactual. kill = false. เติมทุนแล้วปิด = เทรดจริง
REGIME_SHADOW_FILL=false
ALGO_MAX_STACK=2            # ถือไม้ ALGO พร้อมกันได้ 2 (margin/ทุน cap เอง; ไม้ปิด→เข้าใหม่อัตโนมัติ)

# SMALL-ACCOUNT GUARD (2026-07-21): ก่อนเปิดไม้ ALGO เช็คว่าถ้าเปิดที่ MIN_LOT จะเสี่ยง > เพดานไหม
# (min-lot ใหญ่เกินทุน+SL นี้) → เกิน = ข้ามไม้ (stand down) ไม่ over-risk. ramp อัตโนมัติตามทุน.
# ที่ทุน ~1.4k฿ ตอนนี้ = ข้ามทุกไม้ (เสี่ยง 9-52%); พอทุนโต ~13k→27k→54k ไม้ค่อยๆ เปิดได้. kill = false.
# ⚠️ DEMO: ปิด guard ให้บอทรันปกติ (เข้าทุกไม้ = เก็บ data ครบ ไม่เอนเอียง SL size).
# 🔴 ต้องเปิดกลับ (=true) ก่อนใช้เงินจริง — ไม่งั้นบัญชีเล็กไม่มีตัวป้องกัน over-risk
ALGO_SIZE_STANDDOWN=false
ALGO_MAX_TRADE_RISK_PCT=0.02   # เพดาน risk/ไม้ ALGO 2% (ใช้เมื่อ guard=true)

# TSMOM-D1 (2026-07-21) — edge เดียวที่ validated (~31 กลยุทธ์). time-series momentum รายวัน position-based.
# TSMOM_LIVE=true → เปิด position จริงตาม ensemble sign(close_D1−close_D1[L]) + ปิด momentum intraday+fade
# (กัน conflict). tiny-live บน demo เก็บ forward data. exit=flip, SL=chandelier 3×ATR(D1). kill=false (live-reload).
# ⚠️ edge modest+partly-beta = forward-validation ไม่ใช่ money-maker. เปิด stand-down guard กลับก่อนเงินจริง
TSMOM_LIVE=true
TSMOM_SHADOW=false
TSMOM_LOOKBACKS=63,126,252
TSMOM_SL_ATR=3.0
# TSMOM_SL_PIPS > 0 = SL คงที่ (points) แทน chandelier ATR — สำหรับบัญชีเล็กให้เปิด order ได้
# 0 = ใช้ ATR (demo 50k). บัญชี 1000฿: ตั้ง ~500 (risk ~18%/ไม้, พอเปิดได้) ⚠️ SL แคบ = edge หาย
# (backtest: SL<2000p → WR 2-18% โดน noise รูด) = execution-test ไม่ใช่ระบบทำกำไร
TSMOM_SL_PIPS=0

# ── CHART_SHADOW (A/B test — Phase 1 token optimization) ─────
# true  = ยิง terse-variant คู่ขนานเทียบ verbose → log logs/shadow_chart.jsonl
#         (ของจริงใช้ output เดิมตลอด — ไม่กระทบการเทรด แต่จ่าย token เพิ่มชั่วคราว)
# ดูผล: python scripts/shadow_report.py | ปิดเมื่อเก็บ ~100+ cycles พอแล้ว
CHART_SHADOW=false  # ปิด 07-03: ได้ข้อสรุปแล้ว (828 samples, match 22% = Haiku แทนไม่ได้)

# ── NNLB mode (No-Risk-No-Lamborghini) ───────────────────────
# ⚠ NNLB = ข้าม gates — lot คำนวณจากกำไรสะสม (profit-tier)
# *** BASE_EQUITY / EQUITY_PER_LOT = USD → code คูณ rate แปลงเป็นสกุลบัญชีอัตโนมัติ ***
#     บัญชีนี้ THB (rate≈36): ค่า USD ด้านล่าง ×36 = ค่า THB จริง
# profit-tier: กำไรทุก EQUITY_PER_LOT → +0.01 lot (cap MAX_LOT=0.03)
#   equity ≤ $1 (≈36฿)    → skip (ทุนไม่พอ)
#   กำไร $278 (≈10,000฿)  → 0.02 lot
#   กำไร $556 (≈20,000฿)  → 0.03 lot (capped)
NNLB_MODE=false
NNLB_BASE_EQUITY=1     # USD ×36 ≈ 36฿ — floor ขั้นต่ำก่อนเทรด (≈ near-zero, คงพฤติกรรมเดิม)
NNLB_EQUITY_PER_LOT=278  # USD ×36 ≈ 10,008฿ — +0.01 lot ต่อกำไรเท่านี้ (คง 10,000฿ เดิม)
NNLB_MAX_LOSS_PCT=5      # cap max loss ≤ 5% ของ equity

# ── X Accounts / Keywords ────────────────────────────────────
X_ACCOUNTS_TO_FOLLOW=cnnbrk,BBCBreaking,ZeroHedge,markets,kun_purich
X_KEYWORDS=XAUUSD, gold, XAU, bullion, Fed, inflation, Trump, Iran, Israel, ceasefire, geopolitical, war, oil, crude, CPI, rate cut, Hormuz, CENTCOM, Kharg, PPI, FOMC, Pakistan, Pezeshkian, Geneva

ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here

# NEWS_GATE — News Impact score ปรับ conf floor (เปิด 2026-07-05)
NEWS_GATE=true

# Specialist Layer-A shadow data collection (2026-07-15) — 0 order/decision impact, 0 token; appends logs/spec_shadow.jsonl for replay-validator
SPECIALIST_SHADOW=true

# ZRE Zone Re-Entry RR>=2 (v2 fixed-SL) — ENABLE live (2026-07-16, user override replay 'shadow-first')
# containment: trend-align-only, grade A/B score>=78, fresh<=3, proximity 0.4%, cap 2/side + daily cap
ZONE_REENTRY_ENABLED=true
ZONE_REENTRY_SHADOW=true
ZRE_TREND_ALIGN_ONLY=true

# (a) NEWS contradiction dampener — ENABLE (2026-07-16) — ผ่อน oppose-penalty เมื่อ price/flow สวนข่าว
# rare+bounded (floor <=8), gate อื่นคงครบ; แก้เคส 4060 (SELL conf62 โดน NEWS_GATE floor 70)
NEWS_CONTRA_ENABLED=true

# regime-aware vol-target sizing (enabled 2026-07-18, user request)
REGIME_SIZING=true

SPEECH_SUMMARY=true        # Phase 3: dashboard สรุป speech ด้วย Haiku (on-demand, cached ~เศษสตางค์/เดือน); true=เปิด
